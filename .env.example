# Copia aquest fitxer a .env i omple els valors.
#   cp .env.example .env

# Clau de l'API de DeepSeek (https://platform.deepseek.com).
# Si la deixes buida, el projecte funciona igual però amb resums en brut.
DEEPSEEK_API_KEY=

# Opcionals (valors per defecte si no els toques):
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Webhook de make.com (mòdul "Custom webhook"). Opcional: si el defineixes, en
# acabar s'hi envia el JSON del post (p. ex. per rebre l'esborrany a Telegram).
MAKE_WEBHOOK_URL=

# --- Reddit (publicació directa amb PRAW) -----------------------------------
# Credencials d'una "script app" de https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
# Opcional (es genera sol a partir de l'usuari si el deixes buit):
# REDDIT_USER_AGENT=anime-catala-bot/1.0 by u/elteuusuari
