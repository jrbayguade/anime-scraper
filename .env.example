# Copia aquest fitxer a .env i omple els valors.
#   cp .env.example .env

# Clau de l'API de DeepSeek (https://platform.deepseek.com).
# Si la deixes buida, el projecte funciona igual però amb resums en brut.
DEEPSEEK_API_KEY=

# Opcionals (valors per defecte si no els toques):
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Cua de publicació (Cloudflare Worker privat). Totes les sortides hi encuen via
# queue_store.enqueue(); l'extensió de Chrome llegeix la cua i publica a Reddit.
WORKER_URL=
WORKER_WRITE_TOKEN=
# Etiqueta de la font (per agrupar a l'extensió). Cada sortida pot sobreescriure
# 'source'/'source_label' dins del payload (la borsa ho fa amb "borsa"/"Borsa").
# QUEUE_SOURCE=anime
# QUEUE_SOURCE_LABEL=Anime Català

# --- Borsa (borsa.py): heatmap diari del tancament de l'S&P 500 ---
# Subreddit de destí (per defecte r/lapelaeslapela).
# BORSA_SUBREDDIT=lapelaeslapela
# Cloudflare R2: hostatge del PNG generat (cal una URL pública per al post d'imatge).
# R2_PUBLIC_BASE = URL pública del bucket (subdomini *.r2.dev o domini propi), sense / final.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE=

# make.com — LLEGAT, sense ús (es va migrar a la cua del Worker). No cal omplir-ho.
MAKE_WEBHOOK_URL=
