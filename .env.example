# Copia aquest fitxer a .env i omple els valors.
#   cp .env.example .env

# Clau de l'API de DeepSeek (https://platform.deepseek.com).
# Si la deixes buida, el projecte funciona igual però amb resums en brut.
DEEPSEEK_API_KEY=

# Opcionals (valors per defecte si no els toques):
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Webhook de make.com (mòdul "Custom webhook"). L'escenari de make el rep i
# publica el post a r/AnimeCatala. El comparteixen el recull setmanal (main.py)
# i la graella de SX3 (sx3_schedule.py --push): com que l'escenari només penja
# al canal, qualsevol dels dos fluxos pot fer-lo servir.
MAKE_WEBHOOK_URL=
